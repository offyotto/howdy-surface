post_install() {
  cat <<'EOF'
howdy-surface installed.

Run:
  howdy-surface

Then configure explicitly, for example:
  sudo howdy-surface setup --user "$USER" --services hyprlock

Optional FIDO2/PAM support:
  sudo pacman -S pam-u2f
  sudo howdy-surface passkey-enroll --user "$USER" --require-pin
EOF
}

post_upgrade() {
  post_install
}

